generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  passwordHash    String?
  googleId        String?        @unique
  openaiApiKey    String?
  anthropicApiKey String?
  googleApiKey    String?
  groqApiKey      String?
  elevenlabsApiKey String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  creditBalance   CreditBalance?
  sessions        UsageSession[]
  transactions    Transaction[]
  agents          Agent[]
}

model Agent {
  id           String         @id @default(uuid())
  userId       String
  name         String
  systemPrompt String         @db.Text
  voice        String         @default("aura-2-thalia-en")
  sttModel     String         @default("nova-3")
  ttsModel     String         @default("deepgram")
  llmModel     String         @default("gpt-4o-mini")
  language     String         @default("en")
  greeting     String?
  status       String         @default("active")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions     UsageSession[]

  @@index([userId])
}

model CreditBalance {
  id          String   @id @default(uuid())
  userId      String   @unique
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  lastUpdated DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageSession {
  id              String    @id @default(uuid())
  userId          String
  agentId         String?
  startTime       DateTime  @default(now())
  endTime         DateTime?
  durationSeconds Int?
  costAmount      Decimal?  @db.Decimal(10, 2)
  creditsUsed     Int?
  status          String    @default("active")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent           Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([agentId])
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  amount          Decimal  @db.Decimal(10, 2)
  creditsAdded    Int?     // Deprecated: kept for backward compat
  type            String
  stripePaymentId String?  @unique
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
